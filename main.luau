--!strict
--!native
--!optimize 2
-- -----------------------------------------------------------------------------
-- PianoFingeringStreamV3Fast.luau
-- BUFFER-BACKED, NATIVE-COMPILED streaming-LSTM piano fingering predictor.
-- Mathematically identical to PianoFingeringStreamV3.luau but substantially
-- faster per call due to:
--   * contiguous f32 buffer storage (no table-of-tables GC pressure)
--   * --!native compilation of hot loops
--   * numeric type annotations that enable specialized native codegen
--
-- Public API is unchanged:
--   local PF = require(ReplicatedStorage.PianoFingeringStreamV3Fast)
--   local sess = PF.newSession(false)
--   PF.feed(sess, midi, onset, offset)
--   local fingers = PF.drain(sess)
--   local tail = PF.flush(sess)
--   -- or batch:
--   local allFingers = PF.predict(notes)
--
-- Confidence / full posterior:
--   Each entry returned by drain/flush now carries a `confidence: number?`
--   field (softmax probability of the picked finger, masked-logit aware).
--   Callers who need the full 5-finger distribution can use:
--     local dists = PF.drainWithDist(sess)      -- [{idx, finger, dist={p1..p5}}, ...]
--     local allDists = PF.predictWithDist(notes) -- { [eventIdx] = {p1..p5}, ... }
--   drain and drainWithDist share a single internal queue: calling either one
--   resets both so a subsequent call does not re-emit the same events.
-- -----------------------------------------------------------------------------

local CONFIG = {
	embed_dim = 24,
	hidden = 96,
	num_layers = 2,
	num_fingers = 5,
	num_current_feats = 5,
	num_lookahead_feats = 4,
	lookahead_k = 6,
	prev_finger_dim = 6,
	pitch_delta_range = 24,
	pitch_delta_buckets = 49,
	middle_c = 60,
}
-- Derived sizes.  Previously these were hardcoded (num_extra=35, input_dim=59)
-- which silently broke buffer sizing whenever lookahead_k was changed, because
-- build_input_buf writes lookahead_k * num_lookahead_feats floats into a slot
-- past the last lookahead index.  With the trained weights, lookahead_k MUST
-- stay at 6 (the LSTM's first-layer input dimension is baked into w_ih_0), but
-- computing these from CONFIG at least produces a correctly-sized buffer if
-- someone later changes the layout and retrains.  A mismatch between
-- input_dim and the weight matrix is caught during inference by a size check.
CONFIG.num_extra =
	CONFIG.num_current_feats
	+ CONFIG.lookahead_k * CONFIG.num_lookahead_feats
	+ CONFIG.prev_finger_dim
CONFIG.input_dim = CONFIG.embed_dim + CONFIG.num_extra

local FLOAT_SIZE = 4

-- ----------------------------------------------------------------------------
-- Base64 decoder (runs ONCE at require time).
-- ----------------------------------------------------------------------------
local B64_ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
local B64_LOOKUP: {[string]: number} = {}
for i = 1, #B64_ALPHABET do
	B64_LOOKUP[B64_ALPHABET:sub(i, i)] = i - 1
end

local function decode_base64_to_buffer(s: string): buffer
	-- Strip whitespace but keep padding for length calculation
	s = s:gsub("%s+", "")
	local enc_len = #s
	-- Count and strip padding
	local pad = 0
	if s:sub(-2) == "==" then pad = 2
	elseif s:sub(-1) == "=" then pad = 1 end
	local clean = s:gsub("=", "")
	local n = #clean
	-- Byte count: every 4 encoded chars (INCLUDING padding) = 3 bytes,
	-- minus pad bytes.
	local byte_count = (enc_len // 4) * 3 - pad
	local buf = buffer.create(byte_count)
	local out_pos = 0
	local i = 1
	while i <= n do
		local c1 = B64_LOOKUP[clean:sub(i, i)] or 0
		local c2 = B64_LOOKUP[clean:sub(i + 1, i + 1)] or 0
		local c3 = B64_LOOKUP[clean:sub(i + 2, i + 2)] or 0
		local c4 = B64_LOOKUP[clean:sub(i + 3, i + 3)] or 0
		local triple = c1 * 262144 + c2 * 4096 + c3 * 64 + c4  -- 4*6 = 24 bits
		if out_pos < byte_count then
			buffer.writeu8(buf, out_pos, (triple // 65536) % 256)
			out_pos += 1
		end
		if out_pos < byte_count then
			buffer.writeu8(buf, out_pos, (triple // 256) % 256)
			out_pos += 1
		end
		if out_pos < byte_count then
			buffer.writeu8(buf, out_pos, triple % 256)
			out_pos += 1
		end
		i += 4
	end
	return buf
end

