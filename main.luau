-- Decode everything once at module load
local W = {
	embed   = decode_base64_to_buffer(BLOB_EMBED),
	w_ih_0  = decode_base64_to_buffer(BLOB_W_IH_0),
	w_hh_0  = decode_base64_to_buffer(BLOB_W_HH_0),
	b_0     = decode_base64_to_buffer(BLOB_B_0),
	w_ih_1  = decode_base64_to_buffer(BLOB_W_IH_1),
	w_hh_1  = decode_base64_to_buffer(BLOB_W_HH_1),
	b_1     = decode_base64_to_buffer(BLOB_B_1),
	head_w  = decode_base64_to_buffer(BLOB_HEAD_W),
	head_b  = decode_base64_to_buffer(BLOB_HEAD_B),
}

-- Precomputed dimensions
local HIDDEN = CONFIG.hidden
local NUM_FINGERS = CONFIG.num_fingers
local EMBED_DIM = CONFIG.embed_dim
local INPUT_DIM = CONFIG.input_dim        -- embed_dim + num_extra (derived)
local L0_INPUT = INPUT_DIM                -- layer 0 input width
local L1_INPUT = HIDDEN                   -- layer 1 input width (from layer 0 output)
local FOUR_H = 4 * HIDDEN

-- Sanity-check that the (now-derived) INPUT_DIM matches the shape the trained
-- weights expect.  w_ih_0 is stored row-major as (4*hidden, input_dim) f32, so
-- its byte length must equal 4 * hidden * input_dim * FLOAT_SIZE.  If a future
-- config change makes these diverge, fail loudly at require-time instead of
-- later producing nonsense predictions or — worse — a silent buffer-OOB.
do
	local expected_w_ih_0 = 4 * HIDDEN * INPUT_DIM * FLOAT_SIZE
	local actual_w_ih_0 = buffer.len(W.w_ih_0)
	if actual_w_ih_0 ~= expected_w_ih_0 then
		error(string.format(
			"PianoFingering: input_dim mismatch.  CONFIG yields input_dim=%d "
			.. "(embed=%d + extra=%d, where extra = num_current_feats(%d) "
			.. "+ lookahead_k(%d) * num_lookahead_feats(%d) + prev_finger_dim(%d)), "
			.. "but trained w_ih_0 expects input_dim=%d.  The bundled weights are "
			.. "only valid for the exact feature layout they were trained on — "
			.. "changing lookahead_k / num_current_feats / etc. requires "
			.. "retraining.",
			INPUT_DIM,
			EMBED_DIM, CONFIG.num_extra,
			CONFIG.num_current_feats,
			CONFIG.lookahead_k,
			CONFIG.num_lookahead_feats,
			CONFIG.prev_finger_dim,
			actual_w_ih_0 // (4 * HIDDEN * FLOAT_SIZE)
		))
	end
end

-- ----------------------------------------------------------------------------
-- Math helpers (type-annotated for native codegen)
-- ----------------------------------------------------------------------------
local function sigmoid(x: number): number
	if x >= 0 then
		return 1 / (1 + math.exp(-x))
	else
		local z = math.exp(x)
		return z / (1 + z)
	end
end

local tanh = math.tanh

-- ----------------------------------------------------------------------------
-- LSTM step (buffer-backed, type-annotated, fused 4-gate inner loop).
--
-- All arguments are buffers of f32.  The function reads:
--   w_ih at row-major (4H, in_dim), w_hh at (4H, H), bias (4H,), x (in_dim,),
--   h_prev (H,), c_prev (H,).
-- And writes:
--   h_out (H,), c_out (H,).
--
-- Gate layout in 4H dimension: i, f, g, o (each H wide, contiguous).
--
-- ── Why the loop is structured this way ─────────────────────────────────────
-- Naive layout iterates k=0..4H-1 and computes one pre-activation per outer
-- step, reading x[j] and h_prev[j] inside each inner loop.  That re-reads
-- every x[j] / h_prev[j] FOUR TIMES (once per gate band).  For layer 0
-- (in_dim=155, hidden=96) that's 384 × 251 ≈ 96k buffer reads of x/h_prev
-- per LSTM step — and we run two layers per emit, two emits per chord on
-- average, so this dominates the streaming pipeline's frame budget.
--
-- Fused version: outer loop runs k=0..H-1, computing all four gates for
-- each output unit.  x[j] and h_prev[j] are read ONCE per j in the inner
-- loop and multiplied against the four gate-band weight rows.  Total
-- multiplies are unchanged (still 4×H×(in_dim+hidden)), but x/h_prev
-- reads drop ~75% — roughly 96k → 24k for layer 0.
--
-- We also snapshot x and h_prev into Lua tables at the top.  Three reasons:
--   1. Table reads are cheaper than buffer.readf32 calls in the hot loop.
--   2. The snapshot makes h_prev == h_out aliasing safe (the original
--      two-pass version was safe only because preact intermediated; the
--      fused version writes h_out[k] inside the outer k loop, so without
--      the snapshot a later k iteration would see clobbered h_prev).
--   3. The snapshot tables are reused across emits via the session, so
--      there is no per-emit allocation cost.
--
-- The preact scratch buffer is no longer needed — gate pre-activations
-- live in stack locals (si / sf / sg / so).
-- ----------------------------------------------------------------------------
local function lstm_step(
	w_ih: buffer, w_hh: buffer, bias: buffer,
	x: buffer, h_prev: buffer, c_prev: buffer,
	in_dim: number, hidden: number,
	h_out: buffer, c_out: buffer,
	x_snap: {number}, h_snap: {number}    -- session-owned scratch tables
)
	local fs: number = FLOAT_SIZE
	local in_stride: number = in_dim * fs
	local hh_stride: number = hidden * fs
	local band_b: number  = hidden * fs           -- bytes between gate bands in bias
	local band_ih: number = hidden * in_stride    -- bytes between gate bands in w_ih
	local band_hh: number = hidden * hh_stride    -- bytes between gate bands in w_hh

	-- Snapshot the inputs into Lua tables once.  See header for the three
	-- reasons this is faster despite the extra read pass.
	do
		local off: number = 0
		for j = 1, in_dim do
			x_snap[j] = buffer.readf32(x, off)
			off += fs
		end
		off = 0
		for j = 1, hidden do
			h_snap[j] = buffer.readf32(h_prev, off)
			off += fs
		end
	end

	-- Pre-compute the 2× / 3× band offsets so the inner loop does not
	-- re-multiply each iteration.  The Luau native compiler will fold
	-- these constants into the addresses regardless, but spelling them
	-- out makes the intent obvious and matches what the optimised path
	-- looks like once codegen finishes with it.
	local band_b2: number  = 2 * band_b
	local band_b3: number  = 3 * band_b
	local band_ih2: number = 2 * band_ih
	local band_ih3: number = 3 * band_ih
	local band_hh2: number = 2 * band_hh
	local band_hh3: number = 3 * band_hh

	local row_ih: number = 0
	local row_hh: number = 0
	local k_off: number  = 0
	for _ = 0, hidden - 1 do
		-- Bias initial values for the four gates (i, f, g, o) at row k.
		local si: number = buffer.readf32(bias, k_off)
		local sf: number = buffer.readf32(bias, k_off + band_b)
		local sg: number = buffer.readf32(bias, k_off + band_b2)
		local so: number = buffer.readf32(bias, k_off + band_b3)

		-- x · W_ih band.  Read x[j] once into a local, multiply against the
		-- four gate rows of w_ih.  off_w walks down the i-band; the f / g /
		-- o bands sit at fixed +band_ih{,2,3} offsets from there.
		local off_w: number = row_ih
		for j = 1, in_dim do
			local xj: number = x_snap[j]
			si += buffer.readf32(w_ih, off_w)              * xj
			sf += buffer.readf32(w_ih, off_w + band_ih)    * xj
			sg += buffer.readf32(w_ih, off_w + band_ih2)   * xj
			so += buffer.readf32(w_ih, off_w + band_ih3)   * xj
			off_w += fs
		end

		-- h_prev · W_hh band.  Same pattern as above on the recurrent side.
		local off_h: number = row_hh
		for j = 1, hidden do
			local hj: number = h_snap[j]
			si += buffer.readf32(w_hh, off_h)              * hj
			sf += buffer.readf32(w_hh, off_h + band_hh)    * hj
			sg += buffer.readf32(w_hh, off_h + band_hh2)   * hj
			so += buffer.readf32(w_hh, off_h + band_hh3)   * hj
			off_h += fs
		end

		-- Combine gates into the cell + hidden update.  c_prev[k] is read
		-- into a local before the c_out[k] write so c_prev == c_out aliasing
		-- stays safe.
		local i_gate: number = sigmoid(si)
		local f_gate: number = sigmoid(sf)
		local g_val:  number = tanh(sg)
		local o_gate: number = sigmoid(so)
		local c_prev_k: number = buffer.readf32(c_prev, k_off)
		local c_new: number = f_gate * c_prev_k + i_gate * g_val
		buffer.writef32(c_out, k_off, c_new)
		buffer.writef32(h_out, k_off, o_gate * tanh(c_new))

		row_ih += in_stride
		row_hh += hh_stride
		k_off  += fs
	end
end

-- Linear head: out (num_fingers,) = head_w (num_fingers, H) * h + head_b
local function linear_head(h: buffer, out: buffer)
	for i = 0, NUM_FINGERS - 1 do
		local row_base: number = i * HIDDEN * FLOAT_SIZE
		local s: number = buffer.readf32(W.head_b, i * FLOAT_SIZE)
		for j = 0, HIDDEN - 1 do
			s += buffer.readf32(W.head_w, row_base + j * FLOAT_SIZE)
				* buffer.readf32(h, j * FLOAT_SIZE)
		end
		buffer.writef32(out, i * FLOAT_SIZE, s)
	end
end

local function argmax5(buf: buffer): number
	local best_i: number = 1
	local best_v: number = buffer.readf32(buf, 0)
	for i = 1, 4 do
		local v: number = buffer.readf32(buf, i * FLOAT_SIZE)
		if v > best_v then best_v = v; best_i = i + 1 end
	end
	return best_i
end

-- Numerically-stable softmax over the 5 finger logits.  Writes probabilities
-- into `out` (same layout as `logits`) and returns the argmax alongside its
-- probability.  Masked entries in `logits` (−inf) produce probability 0 in
-- `out` without any special-case handling thanks to the standard max-shift
-- trick.  Hot path — kept branch-free over the 5 elements.
local function softmax5(logits: buffer, out: buffer): (number, number)
	local l0: number = buffer.readf32(logits, 0)
	local l1: number = buffer.readf32(logits, 1 * FLOAT_SIZE)
	local l2: number = buffer.readf32(logits, 2 * FLOAT_SIZE)
	local l3: number = buffer.readf32(logits, 3 * FLOAT_SIZE)
	local l4: number = buffer.readf32(logits, 4 * FLOAT_SIZE)

	local m: number = l0
	local best_i: number = 1
	if l1 > m then m = l1; best_i = 2 end
	if l2 > m then m = l2; best_i = 3 end
	if l3 > m then m = l3; best_i = 4 end
	if l4 > m then m = l4; best_i = 5 end

	-- If every logit is −inf (every finger masked) the max-shift would be
	-- −inf − −inf = nan; emit a uniform distribution and an arbitrary best.
	if m == -math.huge then
		local u: number = 1 / NUM_FINGERS
		for i = 0, NUM_FINGERS - 1 do
			buffer.writef32(out, i * FLOAT_SIZE, u)
		end
		return 1, u
	end

	local e0: number = math.exp(l0 - m)
	local e1: number = math.exp(l1 - m)
	local e2: number = math.exp(l2 - m)
	local e3: number = math.exp(l3 - m)
	local e4: number = math.exp(l4 - m)
	local z: number = e0 + e1 + e2 + e3 + e4
	local inv: number = 1 / z

	local p0: number = e0 * inv
	local p1: number = e1 * inv
	local p2: number = e2 * inv
	local p3: number = e3 * inv
	local p4: number = e4 * inv
	buffer.writef32(out, 0,               p0)
	buffer.writef32(out, 1 * FLOAT_SIZE,  p1)
	buffer.writef32(out, 2 * FLOAT_SIZE,  p2)
	buffer.writef32(out, 3 * FLOAT_SIZE,  p3)
	buffer.writef32(out, 4 * FLOAT_SIZE,  p4)

	local best_p: number
	if     best_i == 1 then best_p = p0
	elseif best_i == 2 then best_p = p1
	elseif best_i == 3 then best_p = p2
	elseif best_i == 4 then best_p = p3
	else                    best_p = p4 end
	return best_i, best_p
end

-- ----------------------------------------------------------------------------
-- Feature building. Writes directly into a provided input buffer.
-- ----------------------------------------------------------------------------
local BLACK = {[1]=true,[3]=true,[6]=true,[8]=true,[10]=true}
local function isBlack(m: number): number return BLACK[m % 12] and 1 or 0 end

local function build_input_buf(
	buf: buffer,
	cur_midi: number, cur_onset: number, cur_offset: number,
	prev_midi: number, prev_onset: number,
	futures: {any},
	is_first: boolean,
	prev_finger: number
)
	local R = CONFIG.pitch_delta_range
	local delta = cur_midi - prev_midi
	if delta < -R then delta = -R elseif delta > R then delta = R end
	local embed_idx = delta + R  -- 0-indexed row into embed buffer
	local E = EMBED_DIM

	-- Zero the buffer first (one shot; cheap)
	buffer.fill(buf, 0, 0, INPUT_DIM * FLOAT_SIZE)

	-- Copy embedding row into first E slots
	local src_base: number = embed_idx * E * FLOAT_SIZE
	for i = 0, E - 1 do
		buffer.writef32(buf, i * FLOAT_SIZE,
			buffer.readf32(W.embed, src_base + i * FLOAT_SIZE))
	end

	-- Current-note features start at offset E
	local NC = CONFIG.num_current_feats
	local onset_dt = math.max(0, cur_onset - prev_onset)
	local duration = math.max(1e-3, cur_offset - cur_onset)
	buffer.writef32(buf, (E + 0) * FLOAT_SIZE, isBlack(cur_midi))
	buffer.writef32(buf, (E + 1) * FLOAT_SIZE, isBlack(prev_midi))
	buffer.writef32(buf, (E + 2) * FLOAT_SIZE, math.log(1 + onset_dt))
	buffer.writef32(buf, (E + 3) * FLOAT_SIZE, math.log(1 + duration))
	buffer.writef32(buf, (E + 4) * FLOAT_SIZE, is_first and 1 or 0)

	-- Lookahead slots
	local NL = CONFIG.num_lookahead_feats
	for k = 1, CONFIG.lookahead_k do
		local base = E + NC + (k - 1) * NL
		local fut = futures[k]
		if fut then
			local fd = fut.midi - cur_midi
			if fd < -R then fd = -R elseif fd > R then fd = R end
			buffer.writef32(buf, (base + 0) * FLOAT_SIZE, fd / R)
			buffer.writef32(buf, (base + 1) * FLOAT_SIZE, isBlack(fut.midi))
			buffer.writef32(buf, (base + 2) * FLOAT_SIZE, math.log(1 + math.max(0, fut.onset - cur_onset)))
			-- slot 3 stays 0 (not padding)
		else
			-- Padding slot: only the padding flag is 1
			buffer.writef32(buf, (base + 3) * FLOAT_SIZE, 1)
		end
	end

	-- Previous-finger one-hot
	local prev_base = E + NC + CONFIG.lookahead_k * NL
	-- prev_finger is 0 (none) or 1..5. Writing at prev_base + prev_finger.
	buffer.writef32(buf, (prev_base + prev_finger) * FLOAT_SIZE, 1)
end

-- ----------------------------------------------------------------------------
-- Session
-- ----------------------------------------------------------------------------
export type Session = {
	isLeftHand: boolean,
	-- pending is a head-indexed circular slice: live entries occupy
	-- [pending_head .. pending_head + pending_count - 1].  This avoids the
	-- O(k) shift cost of table.remove(pending, 1) on every emit, which
	-- noticeably hits big pieces (lookahead_k = 6 means ~6 entries shift
	-- per emit, multiplied by thousands of emits per song).
	pending: {any},
	pending_head: number,
	pending_count: number,
	nextIdx: number,
	-- Per-layer hidden / cell state (persist across steps)
	h0: buffer, c0: buffer, h1: buffer, c1: buffer,
	-- Scratch for the inference step
	input_buf: buffer,
	preact: buffer,        -- vestigial; retained in the type so external
	                       -- callers that reference it still type-check.
	                       -- The fused lstm_step no longer reads or writes it.
	logits: buffer,
	probs: buffer,         -- NUM_FINGERS f32s; softmax of logits (post-mask)
	-- Snapshot scratch tables used by lstm_step.  x_snap is sized for the
	-- larger of the two layer input widths (INPUT_DIM); h_snap holds the
	-- HIDDEN-wide previous-hidden snapshot.  Reused across emits and across
	-- the two layers within a single emit, so they cost one allocation per
	-- session lifetime instead of one per step.
	x_snap: {number},
	h_snap: {number},
	-- Reusable futures slot table — emit_oldest writes the next lookahead_k
	-- pending entries here so build_input_buf can index by k without us
	-- allocating a fresh table every emit.
	futures: {any},
	prev_midi: number, prev_onset: number, prev_offset: number,
	prev_finger: number,
	firstDone: boolean,
	-- Per-emit output carries both the argmax finger and its softmax
	-- probability so downstream callers can distinguish a 95%-confident pick
	-- from a 40/35/25 three-way tie.  The full distribution is available via
	-- PianoFingering.drainWithDist if all five probabilities are needed.
	pendingOut: {{idx: number, finger: number, confidence: number?}},
	pendingDist: {{idx: number, finger: number, dist: {number}}},
	-- When false, emit_oldest skips the per-emit pendingDist allocation
	-- entirely (saves a table + a 5-entry subtable per emit, which is
	-- meaningful GC pressure on big pieces).  Defaults true to preserve
	-- the existing API; pass false to newSession when you only call
	-- drain / flush and never the *WithDist variants.
	wantDist: boolean,
	-- Same-hand overlap tracker.  recent is kept in [1 .. recent_count]
	-- with stale slots past recent_count retained as a tiny entry-table
	-- pool so the per-emit compaction pass can reuse them instead of
	-- allocating a fresh entry every step.
	recent: {{finger: number, offset: number}},
	recent_count: number,
}

local PianoFingering = {}

function PianoFingering.newSession(isLeftHand: boolean, wantDist: boolean?): Session
	local H_BYTES = HIDDEN * FLOAT_SIZE
	return {
		isLeftHand = isLeftHand,
		pending = {},
		pending_head = 1,
		pending_count = 0,
		nextIdx = 1,
		h0 = buffer.create(H_BYTES),
		c0 = buffer.create(H_BYTES),
		h1 = buffer.create(H_BYTES),
		c1 = buffer.create(H_BYTES),
		input_buf = buffer.create(INPUT_DIM * FLOAT_SIZE),
		preact = buffer.create(FOUR_H * FLOAT_SIZE),
		logits = buffer.create(NUM_FINGERS * FLOAT_SIZE),
		probs = buffer.create(NUM_FINGERS * FLOAT_SIZE),
		x_snap = table.create(INPUT_DIM, 0),
		h_snap = table.create(HIDDEN, 0),
		futures = table.create(CONFIG.lookahead_k),
		prev_midi = 0,
		prev_onset = 0,
		prev_offset = 0,
		prev_finger = 0,
		firstDone = false,
		pendingOut = {},
		pendingDist = {},
		-- Default true preserves the original behaviour for callers that
		-- did not pass the new parameter.  Hot callers pass false.
		wantDist = wantDist == nil and true or wantDist,
		recent = {},
		recent_count = 0,
	}
end

local function emit_oldest(sess: Session)
	local pending = sess.pending
	local head = sess.pending_head
	local cur = pending[head]

	-- Reuse the session's futures scratch table.  Writing every slot
	-- unconditionally clears stale entries from the previous emit; nil at
	-- a slot means "past the end", which build_input_buf treats as padding.
	local futures = sess.futures
	for k = 1, CONFIG.lookahead_k do
		futures[k] = pending[head + k]
	end

	-- Use current note's own data as "previous" if this is the first emit
	local prev_midi: number = sess.firstDone and sess.prev_midi or cur.midi
	local prev_onset: number = sess.firstDone and sess.prev_onset or cur.onset

	build_input_buf(
		sess.input_buf,
		cur.midi, cur.onset, cur.offset,
		prev_midi, prev_onset,
		futures,
		not sess.firstDone,
		sess.prev_finger
	)
	sess.firstDone = true

	-- Layer 0: x = input_buf; h/c in place on sess.h0/sess.c0.  The fused
	-- lstm_step snapshots h_prev into h_snap before any writes to h_out, so
	-- h_prev == h_out aliasing remains safe; c_prev[k] is read into a local
	-- before the c_out[k] write so c_prev == c_out aliasing is safe too.
	-- Together this lets us avoid the four scratch->state copies the old
	-- code required.
	local x_snap = sess.x_snap
	local h_snap = sess.h_snap
	lstm_step(
		W.w_ih_0, W.w_hh_0, W.b_0,
		sess.input_buf, sess.h0, sess.c0,
		L0_INPUT, HIDDEN,
		sess.h0, sess.c0,
		x_snap, h_snap
	)

	-- Layer 1: x = sess.h0 (layer 0 output); h/c in place on sess.h1/sess.c1.
	lstm_step(
		W.w_ih_1, W.w_hh_1, W.b_1,
		sess.h0, sess.h1, sess.c1,
		L1_INPUT, HIDDEN,
		sess.h1, sess.c1,
		x_snap, h_snap
	)

	-- Head: h1 -> logits
	linear_head(sess.h1, sess.logits)

	-- --------------------------------------------------------------------
	-- Same-hand overlap mask.
	--
	-- The NN has no feature telling it which fingers are still physically
	-- held at cur.onset (its input only knows the immediately-previous
	-- note and a pitch-delta lookahead — it does not see offset timing
	-- for earlier anchors).  Without a mask it will happily re-emit a
	-- finger that is still sounding from a prior note, which is
	-- physically impossible and drives a lot of the "LH 3 2 5" style
	-- glitches downstream.
	--
	-- We track recent anchor outputs in sess.recent and, at each new
	-- note, zero-out (set to -inf) any finger whose previous note has
	-- not yet released (offset > cur.onset).  If every finger is held
	-- we skip the mask rather than return garbage — the hand can't
	-- physically play in that state and we let the model's best guess
	-- fall through for downstream repair.
	--
	-- Implementation: 5 stack-allocated booleans instead of a hash map.
	-- The original `local masked = {}` allocated a new table every emit;
	-- on big pieces that GC pressure showed up in frame timing.
	-- --------------------------------------------------------------------
	local m1, m2, m3, m4, m5 = false, false, false, false, false
	local free_count: number = NUM_FINGERS
	local rc: number = sess.recent_count
	if rc > 0 then
		local recent = sess.recent
		local cur_onset = cur.onset
		for i = 1, rc do
			local r = recent[i]
			if r.offset > cur_onset then
				local f = r.finger
				if     f == 1 and not m1 then m1 = true; free_count -= 1
				elseif f == 2 and not m2 then m2 = true; free_count -= 1
				elseif f == 3 and not m3 then m3 = true; free_count -= 1
				elseif f == 4 and not m4 then m4 = true; free_count -= 1
				elseif f == 5 and not m5 then m5 = true; free_count -= 1
				end
			end
		end
	end
	if free_count > 0 and free_count < NUM_FINGERS then
		local NEG_INF: number = -math.huge
		if m1 then buffer.writef32(sess.logits, 0,              NEG_INF) end
		if m2 then buffer.writef32(sess.logits, 1 * FLOAT_SIZE, NEG_INF) end
		if m3 then buffer.writef32(sess.logits, 2 * FLOAT_SIZE, NEG_INF) end
		if m4 then buffer.writef32(sess.logits, 3 * FLOAT_SIZE, NEG_INF) end
		if m5 then buffer.writef32(sess.logits, 4 * FLOAT_SIZE, NEG_INF) end
	end

	-- Compute argmax + full softmax distribution in one pass.  The
	-- distribution is used by downstream code (VertCost) to scale the
	-- anchor-match bonus by confidence — a 51/49 near-tie should not pull
	-- the DP as hard as a 95/2/1/1/1 confident pick.
	local finger, confidence = softmax5(sess.logits, sess.probs)

	-- Save state for next step
	sess.prev_midi = cur.midi
	sess.prev_onset = cur.onset
	sess.prev_offset = cur.offset
	sess.prev_finger = finger

	-- Record this anchor for future overlap masking.  In-place compaction
	-- with entry-table reuse: stale slots past the new write index are
	-- left in the array as a tiny pool that the next emit can recycle
	-- instead of allocating a fresh { finger=, offset= } table.  recent_count
	-- tracks the live prefix length so callers don't see the leftovers.
	local recent = sess.recent
	local cur_onset = cur.onset
	local cur_offset = cur.offset
	local write_idx: number = 0
	for i = 1, rc do
		local r = recent[i]
		if r.offset > cur_onset and r.finger ~= finger then
			write_idx += 1
			if write_idx ~= i then
				recent[write_idx] = r
			end
		end
	end
	write_idx += 1
	local entry = recent[write_idx]
	if entry then
		entry.finger = finger
		entry.offset = cur_offset
	else
		recent[write_idx] = { finger = finger, offset = cur_offset }
	end
	sess.recent_count = write_idx

	local out_finger = sess.isLeftHand and -finger or finger
	table.insert(sess.pendingOut, {
		idx = cur.absIdx,
		finger = out_finger,
		confidence = confidence,
	})

	-- Snapshot the full distribution only when the caller asked for it.
	-- Hot callers (RbxMidiPlayer's streaming pipeline) only use drain /
	-- flush, never the *WithDist variants, so allocating a 5-entry table
	-- per emit just to throw it away is pure GC waste.  When wantDist is
	-- false we leave pendingDist empty and drainWithDist becomes a no-op.
	if sess.wantDist then
		table.insert(sess.pendingDist, {
			idx = cur.absIdx,
			finger = out_finger,
			dist = {
				buffer.readf32(sess.probs, 0),
				buffer.readf32(sess.probs, 1 * FLOAT_SIZE),
				buffer.readf32(sess.probs, 2 * FLOAT_SIZE),
				buffer.readf32(sess.probs, 3 * FLOAT_SIZE),
				buffer.readf32(sess.probs, 4 * FLOAT_SIZE),
			},
		})
	end

	-- Pop from the head of the queue.  Setting the slot to nil lets GC
	-- reclaim the cur table; advancing pending_head avoids the O(n) shift
	-- that table.remove(pending, 1) would cost.  When the queue empties we
	-- reset head back to 1 to keep the underlying array compact.
	pending[head] = nil
	sess.pending_head = head + 1
	sess.pending_count -= 1
	if sess.pending_count == 0 then
		sess.pending_head = 1
	end
end

function PianoFingering.feed(
	sess: Session,
	midi: number, onset: number, offset: number
)
	local stored_midi = midi
	if sess.isLeftHand then
		stored_midi = 2 * CONFIG.middle_c - midi
	end
	-- Append at pending_head + pending_count; entries before pending_head
	-- are already nil (popped by emit_oldest).  The queue is allowed to
	-- grow to lookahead_k entries before the next emit fires.
	sess.pending[sess.pending_head + sess.pending_count] = {
		midi = stored_midi, onset = onset, offset = offset,
		absIdx = sess.nextIdx,
	}
	sess.pending_count += 1
	sess.nextIdx += 1
	while sess.pending_count >= 1 + CONFIG.lookahead_k do
		emit_oldest(sess)
	end
end

-- ----------------------------------------------------------------------------
-- cloneSession
--
-- Produces a deep-enough copy of `sess` that the clone can be fed / drained
-- independently of the original without corrupting either session's LSTM
-- state.  Intended use: a DP search wants to try several candidate
-- continuations from the same anchor, score each, and discard the losers.
--
-- Sharing / aliasing contract:
--   * LSTM state buffers (h0/c0/h1/c1) are byte-copied — mutating the clone's
--     state does NOT affect the original.
--   * Scratch buffers (input_buf, preact, logits, probs) are freshly allocated
--     so concurrent emit_oldest calls on both sessions don't trample each
--     other's working memory.  (With a single-threaded Lua VM this matters
--     only if the caller interleaves feed calls between sessions; cheap to
--     do unconditionally and keeps the API footgun-free.)
--   * pending / pendingOut / pendingDist / recent are shallow-copied.  Their
--     entries are append-only dicts that no code path mutates after insert,
--     so sharing entry refs between the clone and the original is safe and
--     avoids a second pass of per-entry table allocation.
--   * Scalars (prev_*, firstDone, nextIdx, isLeftHand) are copied by value.
-- ----------------------------------------------------------------------------
local function copyBuffer(src: buffer): buffer
	local n = buffer.len(src)
	local dst = buffer.create(n)
	buffer.copy(dst, 0, src, 0, n)
	return dst
end

local function shallowCopyList<T>(src: {T}): {T}
	local n = #src
	local dst = table.create(n)
	for i = 1, n do dst[i] = src[i] end
	return dst
end

function PianoFingering.cloneSession(sess: Session): Session
	-- Compact the head-indexed pending queue into a fresh array starting
	-- at 1 so the clone's pending_head can also start at 1.  Without this
	-- the clone would inherit nil leading slots and need to track the
	-- original head offset, which complicates every consumer.
	local pc = sess.pending_count
	local pending_clone = table.create(pc)
	local head = sess.pending_head
	for i = 1, pc do
		pending_clone[i] = sess.pending[head + i - 1]
	end

	-- recent: copy the live prefix into a fresh array.  Stale entries past
	-- recent_count are pool entries — not part of logical state — so they
	-- are not copied; the clone starts with an empty pool and will allocate
	-- its first entry table on demand.
	local rc = sess.recent_count
	local recent_clone = table.create(rc)
	for i = 1, rc do
		local r = sess.recent[i]
		recent_clone[i] = { finger = r.finger, offset = r.offset }
	end

	return {
		isLeftHand   = sess.isLeftHand,
		pending      = pending_clone,
		pending_head = 1,
		pending_count = pc,
		nextIdx      = sess.nextIdx,
		h0 = copyBuffer(sess.h0),
		c0 = copyBuffer(sess.c0),
		h1 = copyBuffer(sess.h1),
		c1 = copyBuffer(sess.c1),
		-- Fresh scratch buffers — see contract above.
		input_buf = buffer.create(INPUT_DIM * FLOAT_SIZE),
		preact    = buffer.create(FOUR_H * FLOAT_SIZE),
		logits    = buffer.create(NUM_FINGERS * FLOAT_SIZE),
		probs     = buffer.create(NUM_FINGERS * FLOAT_SIZE),
		x_snap    = table.create(INPUT_DIM, 0),
		h_snap    = table.create(HIDDEN, 0),
		futures   = table.create(CONFIG.lookahead_k),
		prev_midi   = sess.prev_midi,
		prev_onset  = sess.prev_onset,
		prev_offset = sess.prev_offset,
		prev_finger = sess.prev_finger,
		firstDone   = sess.firstDone,
		pendingOut  = shallowCopyList(sess.pendingOut),
		pendingDist = shallowCopyList(sess.pendingDist),
		wantDist    = sess.wantDist,
		recent      = recent_clone,
		recent_count = rc,
	} :: Session
end

-- ----------------------------------------------------------------------------
-- seed
--
-- Prime prev_* fields as if an anchor note at (midi, onset, offset) had just
-- been emitted with `finger` — WITHOUT running the LSTM for it.  This is the
-- right call at mid-song phrase resets where the caller already knows the
-- previous physical finger choice (e.g. it was user-edited, or the caller
-- just force-picked one to stabilize a pathological branch) but does not want
-- the LSTM's in-memory h/c state to be updated from that note as if it were
-- a true inference step.
--
-- Semantics differ from feed() in two ways:
--   1. No LSTM step runs, so h0/c0/h1/c1 are untouched.  The NEXT emit will
--      therefore condition on whatever LSTM state is already in sess plus
--      the seeded prev_* features.  If the session is brand-new this gives
--      a zero-state-but-informed start, which is generally better than the
--      zero-state-zero-prev start that emit_oldest falls back to when
--      firstDone=false.
--   2. `recent` is updated so the same-hand overlap mask still fires for the
--      seeded note's hold — otherwise a seeded hold-finger could be reused
--      on the very next anchor, exactly the bug the mask exists to prevent.
--
-- `finger` is the PHYSICAL finger index (1..5) regardless of hand.  Caller
-- must mirror-flip incoming user selections for left hand before passing in.
-- Pitch mirroring for LH is applied here to match feed()'s stored_midi path.
-- ----------------------------------------------------------------------------
function PianoFingering.seed(
	sess: Session,
	midi: number, onset: number, offset: number,
	finger: number
)
	local stored_midi = midi
	if sess.isLeftHand then
		stored_midi = 2 * CONFIG.middle_c - midi
	end
	sess.prev_midi   = stored_midi
	sess.prev_onset  = onset
	sess.prev_offset = offset
	sess.prev_finger = finger
	sess.firstDone   = true
	-- Maintain overlap-mask invariant.  Drop stale entries (offset already
	-- past `onset`) to match emit_oldest's pruning so the list doesn't grow
	-- unbounded under repeated seeding.  Same in-place compaction +
	-- entry-table reuse as emit_oldest.
	local recent = sess.recent
	local rc = sess.recent_count
	local write_idx: number = 0
	for i = 1, rc do
		local r = recent[i]
		if r.offset > onset and r.finger ~= finger then
			write_idx += 1
			if write_idx ~= i then
				recent[write_idx] = r
			end
		end
	end
	write_idx += 1
	local entry = recent[write_idx]
	if entry then
		entry.finger = finger
		entry.offset = offset
	else
		recent[write_idx] = { finger = finger, offset = offset }
	end
	sess.recent_count = write_idx
end

function PianoFingering.drain(
	sess: Session
): {{idx: number, finger: number, confidence: number?}}
	-- Both queues are appended to in lockstep by emit_oldest, so resetting
	-- both here keeps them index-aligned for callers that alternate between
	-- drain and drainWithDist across a single streaming session.  Callers
	-- that only ever use one path still pay nothing: the unused queue is
	-- empty and the `= {}` assignment is a single-allocation reset.
	local out = sess.pendingOut
	sess.pendingOut = {}
	sess.pendingDist = {}
	return out
end

function PianoFingering.drainWithDist(
	sess: Session
): {{idx: number, finger: number, dist: {number}}}
	local out = sess.pendingDist
	sess.pendingDist = {}
	sess.pendingOut = {}
	return out
end

function PianoFingering.flush(
	sess: Session
): {{idx: number, finger: number, confidence: number?}}
	while sess.pending_count > 0 do
		emit_oldest(sess)
	end
	return PianoFingering.drain(sess)
end

function PianoFingering.flushWithDist(
	sess: Session
): {{idx: number, finger: number, dist: {number}}}
	while sess.pending_count > 0 do
		emit_oldest(sess)
	end
	return PianoFingering.drainWithDist(sess)
end

function PianoFingering.predict(notes: {any}): {number}
	local T = #notes
	if T == 0 then return {} end
	-- predict() never returns the dist, so opt out of pendingDist
	-- allocations to save GC pressure on long input lists.
	local sessR = PianoFingering.newSession(false, false)
	local sessL = PianoFingering.newSession(true, false)
	local rhMap, lhMap = {}, {}
	for i = 1, T do
		local n = notes[i]
		if n.isLeftHand then
			PianoFingering.feed(sessL, n.midi, n.onset, n.offset)
			table.insert(lhMap, i)
		else
			PianoFingering.feed(sessR, n.midi, n.onset, n.offset)
			table.insert(rhMap, i)
		end
	end
	local outR = PianoFingering.flush(sessR)
	local outL = PianoFingering.flush(sessL)
	local result = table.create(T, 0)
	for _, p in ipairs(outR) do result[rhMap[p.idx]] = p.finger end
	for _, p in ipairs(outL) do result[lhMap[p.idx]] = p.finger end
	return result
end

-- Batch counterpart of predict that also returns the per-event posterior.
-- Return shape:
--   fingers : {number}             -- same layout as predict(): signed finger per event
--   dists   : {{number}}           -- dists[i] is a 5-entry table of unsigned physical-finger
--                                  -- probabilities for event i (aligned with fingers[i]).
--                                  -- Events that were never emitted (shouldn't happen for
--                                  -- finite inputs) get an empty table.
-- The distribution is over PHYSICAL fingers 1..5 regardless of hand; the
-- sign on fingers[i] encodes handedness only.
function PianoFingering.predictWithDist(
	notes: {any}
): ({number}, {{number}})
	local T = #notes
	if T == 0 then return {}, {} end
	-- Explicit wantDist = true keeps the original behaviour even though it
	-- is the default — calling it out makes the contract obvious.
	local sessR = PianoFingering.newSession(false, true)
	local sessL = PianoFingering.newSession(true, true)
	local rhMap, lhMap = {}, {}
	for i = 1, T do
		local n = notes[i]
		if n.isLeftHand then
			PianoFingering.feed(sessL, n.midi, n.onset, n.offset)
			table.insert(lhMap, i)
		else
			PianoFingering.feed(sessR, n.midi, n.onset, n.offset)
			table.insert(rhMap, i)
		end
	end
	local outR = PianoFingering.flushWithDist(sessR)
	local outL = PianoFingering.flushWithDist(sessL)
	local fingers = table.create(T, 0)
	local dists: {{number}} = table.create(T)
	for i = 1, T do dists[i] = {} end
	for _, p in ipairs(outR) do
		local gi = rhMap[p.idx]
		fingers[gi] = p.finger
		dists[gi] = p.dist
	end
	for _, p in ipairs(outL) do
		local gi = lhMap[p.idx]
		fingers[gi] = p.finger
		dists[gi] = p.dist
	end
	return fingers, dists
end

return PianoFingering
